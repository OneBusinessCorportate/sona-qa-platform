# Supabase (project "OB FAQ")
SUPABASE_URL=https://fjsogozwseqoxgddjeig.supabase.co
# Service role key — server-only, NEVER expose to the client. Set in Render dashboard.
SUPABASE_SERVICE_KEY=

# Telegram — bot token and target chat id. Set in Render dashboard.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Auth
JWT_SECRET=change-me

# First-run admin bootstrap (creates an sqa_users row if the table is empty)
SQA_ADMIN_EMAIL=
SQA_ADMIN_PASSWORD=

# Server
PORT=8080
TZ=Asia/Yerevan

# Cron schedules (node-cron syntax). Defaults: daily 18:00, weekly Mon 09:00.
CRON_DAILY=0 18 * * *
CRON_WEEKLY=0 9 * * 1
# Set to "true" to enable scheduled Telegram reports (off by default until configured)
CRON_ENABLED=false

# Daily Sona ticket-count report (counts sqa_reviews forms per day + per accountant).
# Enabled independently of CRON_ENABLED; defaults to CRON_ENABLED when unset.
CRON_TICKETS_ENABLED=true
CRON_TICKETS_DAILY=30 18 * * *
# Optional shared secret for the public cron endpoint /api/cron/sona-tickets-daily
# (required if REQUIRE_AUTH=true). Pass as ?token=... or the X-Cron-Secret header.
CRON_SECRET=

# Client dev API base (used only by Vite dev server)
VITE_API_BASE=http://localhost:8080
